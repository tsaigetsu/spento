// tsconfig.json
{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": false,
    // Настройки для алиасов
    "baseUrl": ".", // Важно, чтобы базовый путь был корнем проекта
    "paths": {
      // Это говорит, что @/ ведет в корень проекта
      "@/*": [
        "./*"
      ]
    }
  }
}